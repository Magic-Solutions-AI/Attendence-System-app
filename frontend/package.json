{
  "name": "attendx",
  "description": "AI-powered desktop attendance management system with face recognition",
  "author": "Magic Solutions",
  "private": true,
  "version": "1.1.0",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "electron:start": "electron .",
    "electron:build": "electron-builder",
    "build:full": "vite build && electron-builder"
  },
  "build": {
    "appId": "com.attendx.app",
    "productName": "AttendX",
    "artifactName": "AttendX.Setup.${ext}",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "renderer/**/*",
      "electron/**/*",
      "package.json"
    ],
    "win": {
      "target": "nsis",
      "artifactName": "AttendX.Setup.${ext}"
    },
    "extraResources": [
      {
        "from": "../backend/target/backend.jar",
        "to": "."
      },
      {
        "from": "../mediapipe_face/dist/app.exe",
        "to": "face_service/app.exe"
      }
    ]
  },
  "dependencies": {
    "@capacitor/android": "^8.2.0",
    "@capacitor/cli": "^8.2.0",
    "@capacitor/core": "^8.2.0",
    "axios": "^1.13.5",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-hot-toast": "^2.6.0",
    "react-router-dom": "^7.13.0",
    "react-webcam": "^7.2.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@tailwindcss/container-queries": "^0.1.1",
    "@tailwindcss/forms": "^0.5.11",
    "@tailwindcss/vite": "^4.1.18",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react-swc": "^4.2.2",
    "autoprefixer": "^10.4.24",
    "electron": "^42.1.0",
    "electron-builder": "^26.8.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.1.18",
    "vite": "^7.3.1"
  }
}
